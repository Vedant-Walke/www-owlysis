---
import '../../styles/global.css';
import { Header } from "@/components/shared/header";
import { SiteFooter } from "@/components/sections/HeroSection";
import { posts } from "@/lib/blog-data";

export async function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{post.title} | Owlysis Blog</title>
		<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
	</head>

	<body class="bg-background text-foreground antialiased min-w-[1280px]">
		<Header />
		<main>
			<!-- Post Hero -->
			<section class="border-b border-border">
				<div class="px-20 pt-32 pb-24 max-w-[1200px]">
					<div class="flex flex-col gap-8">
						<div class="flex items-center gap-4">
							<a href="/blog" class="text-[13px] font-mono text-muted-foreground hover:text-blue-600 transition-colors">← Back to Blog</a>
							<span class="text-border">/</span>
							<span class="text-[11px] font-mono text-blue-600 uppercase tracking-widest">{post.category}</span>
						</div>
						<h1 class="text-[88px] leading-[1.05] tracking-[-0.02em] font-normal" style="font-family: 'Instrument Serif', Georgia, serif;">
							{post.title}
						</h1>
						<div class="flex items-center gap-6 text-[14px] text-muted-foreground font-light">
							<span>{post.date}</span>
							<div class="w-1 h-1 rounded-full bg-border"></div>
							<span>5 min read</span>
						</div>
					</div>
				</div>
			</section>

			<!-- Content Section -->
			<section class="py-24 bg-[#F9F9F7]">
				<div class="px-20 max-w-[1000px]">
					<div class="bg-white border border-border p-16 shadow-[0_4px_30px_-10px_rgba(0,0,0,0.05)]">
						<div class="prose prose-lg max-w-none">
							<p class="text-[22px] leading-[1.7] text-foreground/90 font-light mb-10 italic border-l-4 border-blue-600 pl-8">
								{post.description}
							</p>
							<div class="text-[18px] leading-[1.8] text-muted-foreground font-light space-y-8">
								<p>
									{post.content}
								</p>
								<p>
									As we continue to build Owlysis, our goal remains clear: to provide the most robust, fair, and insightful technical assessment platform in the world. We believe that by leveraging AI responsibly, we can help both companies and candidates find the perfect match.
								</p>
								<p>
									Our platform is constantly evolving, with new features and improvements being rolled out every week. We're committed to staying at the forefront of AI technology to ensure that our assessments remain state-of-the-art.
								</p>
							</div>
						</div>
						
						<div class="mt-20 pt-10 border-t border-border flex items-center justify-between">
							<div class="flex items-center gap-4">
								<div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold">O</div>
								<div class="flex flex-col">
									<span class="text-[14px] font-medium">Owlysis Team</span>
									<span class="text-[12px] text-muted-foreground">Engineering & Product</span>
								</div>
							</div>
							<div class="flex gap-4">
                                <button class="p-3 border border-border hover:border-blue-600 transition-colors">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
                                </button>
                                <button class="p-3 border border-border hover:border-blue-600 transition-colors">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
                                </button>
                            </div>
						</div>
					</div>
				</div>
			</section>

            <!-- Newsletter CTA -->
            <section class="border-y border-border py-24 px-20 text-center">
                <div class="max-w-[700px] mx-auto flex flex-col gap-8">
                    <h2 class="text-[48px] leading-[1.1] font-normal" style="font-family: 'Instrument Serif', Georgia, serif;">Stay updated with our newsletter</h2>
                    <p class="text-[17px] text-muted-foreground font-light">Join over 2,000 engineering leaders receiving our weekly insights on AI and technical hiring.</p>
                    <div class="flex gap-4 max-w-[500px] mx-auto w-full">
                        <input type="email" placeholder="your@email.com" class="flex-1 px-4 py-4 bg-[#f5f5f5] text-[14px] text-[#333] placeholder-[#aaa] outline-none border border-transparent focus:border-[#333] transition-colors" />
                        <button class="px-8 py-4 bg-[#0D0D0B] text-white text-[14px] font-medium hover:bg-blue-600 transition-colors">Subscribe</button>
                    </div>
                </div>
            </section>
		</main>
		<SiteFooter client:load /> 
	</body>
</html>
