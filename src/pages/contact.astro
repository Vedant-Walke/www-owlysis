---
import '../styles/global.css';
import { Header } from "@/components/shared/header";
import { SiteFooter } from "@/components/sections/HeroSection";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Contact Owlysis | Let's Build the Future of Hiring</title>
		<link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
	</head>

	<body class="bg-background text-foreground antialiased min-w-[1280px]">
		<Header />
		<main>
			<!-- Hero Section -->
			<section class="border-b border-border">
				<div class="grid grid-cols-2 px-20 pt-32 pb-24">
					<h1 class="text-[88px] leading-[1.05] tracking-[-0.01em] font-normal" style="font-family: 'Instrument Serif', Georgia, serif;">
						Let's build the<br />
						<em class="text-blue-600" style="font-style: italic">future of hiring</em><br />
						together
					</h1>
					<div class="pl-20 flex flex-col justify-end gap-10 pb-4">
						<p class="text-[19px] leading-[1.6] text-muted-foreground font-light max-w-[480px]">
							Have questions about our AI coding assessments? Our team is here to help you scale your technical hiring with confidence and precision.
						</p>
					</div>
				</div>
			</section>

	<!-- Contact Form & Info Section -->
			<section class="border-b border-border bg-[#F9F9F7]">
				<div class="grid grid-cols-2 px-20 py-28">
					<!-- Left: Contact Info -->
					<div class="flex flex-col gap-16">
						<div class="flex flex-col gap-8">
							<div class="w-10 h-10 bg-blue-600 flex items-center justify-center text-white font-mono text-sm">C</div>
							<h2 class="text-[56px] leading-[1.05] tracking-[-0.02em] font-normal max-w-[500px]" style="font-family: 'Instrument Serif', Georgia, serif;">
								Get in touch with<br />our technical team.
							</h2>
						</div>

						<div class="space-y-12">
							<div class="flex flex-col gap-3">
								<span class="text-[11px] font-mono text-muted-foreground uppercase tracking-widest text-blue-600">Email us</span>
								<a href="mailto:hello@owlysis.com" class="text-[24px] font-medium hover:text-blue-600 transition-colors">hello@owlysis.com</a>
							</div>
							
							<div class="flex flex-col gap-3">
								<span class="text-[11px] font-mono text-muted-foreground uppercase tracking-widest">Our Office</span>
								<p class="text-[18px] text-muted-foreground font-light leading-relaxed">
									Pune, Maharashtra<br />
									India
								</p>
							</div>

							<div class="flex flex-col gap-3">
								<span class="text-[11px] font-mono text-muted-foreground uppercase tracking-widest">Social</span>
								<div class="flex gap-6 mt-1">
									<a href="#" class="text-[14px] font-medium hover:text-blue-600 transition-colors">Twitter</a>
									<a href="#" class="text-[14px] font-medium hover:text-blue-600 transition-colors">LinkedIn</a>
									<a href="#" class="text-[14px] font-medium hover:text-blue-600 transition-colors">GitHub</a>
								</div>
							</div>
						</div>
					</div>

					<!-- Right: Form -->
					<div class="pl-20">
						<div class="bg-white border border-border p-12 shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)]">
							<form class="space-y-6">
								<div class="grid grid-cols-2 gap-6">
									<div class="space-y-2">
										<label for="name" class="text-[12px] font-mono text-muted-foreground uppercase tracking-wider">Full Name</label>
										<input type="text" id="name" name="name" placeholder="John Doe" class="w-full px-4 py-4 bg-[#f5f5f5] text-[14px] text-[#333] placeholder-[#aaa] outline-none border border-transparent focus:border-[#333] transition-colors" required />
									</div>
									<div class="space-y-2">
										<label for="email" class="text-[12px] font-mono text-muted-foreground uppercase tracking-wider">Work Email</label>
										<input type="email" id="email" name="email" placeholder="john@company.com" class="w-full px-4 py-4 bg-[#f5f5f5] text-[14px] text-[#333] placeholder-[#aaa] outline-none border border-transparent focus:border-[#333] transition-colors" required />
									</div>
								</div>

								<div class="space-y-2">
									<label for="company" class="text-[12px] font-mono text-muted-foreground uppercase tracking-wider">Company</label>
									<input type="text" id="company" name="company" placeholder="Acme Inc." class="w-full px-4 py-4 bg-[#f5f5f5] text-[14px] text-[#333] placeholder-[#aaa] outline-none border border-transparent focus:border-[#333] transition-colors" required />
								</div>

								<div class="space-y-2">
									<label for="message" class="text-[12px] font-mono text-muted-foreground uppercase tracking-wider">How can we help?</label>
									<textarea id="message" name="message" rows="4" placeholder="Tell us about your assessment needs..." class="w-full px-4 py-4 bg-[#f5f5f5] text-[14px] text-[#333] placeholder-[#aaa] outline-none border border-transparent focus:border-[#333] transition-colors resize-none" required></textarea>
								</div>

								<button type="submit" class="w-full py-5 bg-foreground text-background text-[15px] font-medium hover:bg-blue-600 transition-colors duration-300">
									Send Message
								</button>
								
								<p class="text-[12px] text-muted-foreground font-light text-center">
									By submitting this form, you agree to our privacy policy.
								</p>
							</form>
						</div>
					</div>
				</div>
			</section>

			<!-- FAQ simple section -->
			<section class="border-b border-border">
				<div class="px-20 py-24">
					<div class="max-w-[800px] space-y-12">
						<h3 class="text-[32px] font-normal" style="font-family: 'Instrument Serif', Georgia, serif;">Common Questions</h3>
						<div class="grid gap-10">
							<div class="space-y-3">
								<h4 class="text-[17px] font-medium">How many languages do you support?</h4>
								<p class="text-[15px] text-muted-foreground font-light leading-relaxed">We support over 50 programming languages, from high-level web frameworks to low-level systems programming.</p>
							</div>
							<div class="space-y-3">
								<h4 class="text-[17px] font-medium">Can I customize the assessment content?</h4>
								<p class="text-[15px] text-muted-foreground font-light leading-relaxed">Yes, you can create your own questions or use our AI to generate tailored assessments based on your job descriptions.</p>
							</div>
						</div>
					</div>
				</div>
			</section>
		</main>
		<SiteFooter client:load /> 
	</body>
</html>
